{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "mobile/package.json",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/mobile/(.*)",
      "dest": "/mobile/$1",
      "continue": true
    },
    {
      "src": "/mobile",
      "dest": "/mobile/index.html"
    },
    {
      "src": "/static/(.*)",
      "dest": "/frontend/static/$1",
      "continue": true
    },
    {
      "src": "/favicon.ico",
      "dest": "/frontend/favicon.ico"
    },
    {
      "src": "/manifest.json",
      "dest": "/frontend/manifest.json"
    },
    {
      "src": "/logo(.*).png",
      "dest": "/frontend/logo$1.png"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1",
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
